{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/KeySwitcher.slnx"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/KeySwitcher/KeySwitcher.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish-release",
      "type": "process",
      "command": "dotnet",
      "args": [
        "publish",
        "${workspaceFolder}/KeySwitcher/KeySwitcher.csproj",
        "-c",
        "Release"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}

